# Database Configuration (Supabase Postgres)
# Use your project URL and Transaction Pooler URI from:
# Supabase Dashboard -> Project Settings -> Database -> Connection string
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<POOLER-HOST>:6543/postgres

# Optional direct connection (may fail on IPv4-only networks)
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Fallback legacy variable (optional)
DATABASE_URL=
DATA_PROVIDER=supabase

# Session Secret
SESSION_SECRET=frozenhub-secret-key-change-in-production

# Client-side Supabase auth variables
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Optional explicit OAuth callback URL (recommended for stable production callback)
VITE_AUTH_REDIRECT_URL=https://your-domain.com/auth/callback

# Server Port
PORT=8080

# Vite dev server port
VITE_DEV_PORT=5173

# Environment
NODE_ENV=development

