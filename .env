# Database Configuration (Supabase Postgres)
# Project ref: xunlduzvfaokkqnzwuoi
# Use the Transaction Pooler URI from Supabase Dashboard:
# Project Settings -> Database -> Connection string -> Transaction pooler
SUPABASE_URL=https://xunlduzvfaokkqnzwuoi.supabase.co
SUPABASE_POOLER_URL=postgresql://postgres.xunlduzvfaokkqnzwuoi:Aldrinreyes123!@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Optional fallback direct URI (often fails on IPv4-only networks)
SUPABASE_DATABASE_URL=postgresql://postgres:Aldrinreyes123!@db.xunlduzvfaokkqnzwuoi.supabase.co:5432/postgres

# Connection selection priority in server/db.ts is:
# SUPABASE_POOLER_URL -> SUPABASE_DATABASE_URL -> DATABASE_URL
DATA_PROVIDER=supabase
# Session Secret
SESSION_SECRET=frozenhub-secret-key-change-in-production

# Server Port
PORT=8080

# Vite dev server port
VITE_DEV_PORT=5173

# Environment
NODE_ENV=development

