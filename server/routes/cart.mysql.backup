import { RequestHandler } from "express";
import { getConnection } from "../db";
import { randomUUID } from "crypto";

// Get user's cart with items
export const getCart: RequestHandler = async (req, res) => {
  if (!req.session?.userId) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const connection = await getConnection();
  try {
    // Get or create cart
    let [carts] = await connection.query(
      "SELECT id FROM carts WHERE user_id = ?",
      [req.session.userId]
    );

    let cartId: string;
    if ((carts as any[]).length === 0) {
      // Create new cart
      cartId = randomUUID();
      await connection.query(
        "INSERT INTO carts (id, user_id) VALUES (?, ?)",
        [cartId, req.session.userId]
      );
    } else {
      cartId = (carts as any[])[0].id;
    }

    // Get cart items with product details
    const [items] = await connection.query(
      `SELECT 
        ci.id as cart_item_id,
        ci.quantity,
        p.id, p.name, p.sku, p.category, p.description, 
        p.price, p.cost, p.image, p.active
      FROM cart_items ci
      JOIN products p ON ci.product_id = p.id
      WHERE ci.cart_id = ? AND p.active = true
      ORDER BY ci.added_at DESC`,
      [cartId]
    );

    res.json({
      cartId,
      items: (items as any[]).map(item => ({
        cartItemId: item.cart_item_id,
        product: {
          id: item.id,
          name: item.name,
          sku: item.sku,
          category: item.category,
          description: item.description,
          price: parseFloat(item.price),
          cost: parseFloat(item.cost),
          image: item.image,
          active: Boolean(item.active),
        },
        quantity: item.quantity,
      })),
    });
  } catch (error) {
    console.error("Error fetching cart:", error);
    res.status(500).json({ error: "Failed to fetch cart" });
  } finally {
    connection.release();
  }
};

// Add item to cart
export const addToCart: RequestHandler = async (req, res) => {
  if (!req.session?.userId) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const { productId, quantity = 1 } = req.body;

  if (!productId) {
    return res.status(400).json({ error: "Product ID is required" });
  }

  if (quantity < 1) {
    return res.status(400).json({ error: "Quantity must be at least 1" });
  }

  const connection = await getConnection();
  try {
    // Verify product exists and is active
    const [products] = await connection.query(
      "SELECT id, name FROM products WHERE id = ? AND active = true",
      [productId]
    );

    if ((products as any[]).length === 0) {
      return res.status(404).json({ error: "Product not found or inactive" });
    }

    // Get or create cart
    let [carts] = await connection.query(
      "SELECT id FROM carts WHERE user_id = ?",
      [req.session.userId]
    );

    let cartId: string;
    if ((carts as any[]).length === 0) {
      cartId = randomUUID();
      await connection.query(
        "INSERT INTO carts (id, user_id) VALUES (?, ?)",
        [cartId, req.session.userId]
      );
    } else {
      cartId = (carts as any[])[0].id;
    }

    // Check if item already in cart
    const [existingItems] = await connection.query(
      "SELECT id, quantity FROM cart_items WHERE cart_id = ? AND product_id = ?",
      [cartId, productId]
    );

    if ((existingItems as any[]).length > 0) {
      // Update quantity
      const newQuantity = (existingItems as any[])[0].quantity + quantity;
      await connection.query(
        "UPDATE cart_items SET quantity = ? WHERE id = ?",
        [newQuantity, (existingItems as any[])[0].id]
      );
    } else {
      // Add new item
      const itemId = randomUUID();
      await connection.query(
        "INSERT INTO cart_items (id, cart_id, product_id, quantity) VALUES (?, ?, ?, ?)",
        [itemId, cartId, productId, quantity]
      );
    }

    res.json({ 
      success: true, 
      message: "Item added to cart",
      productName: (products as any[])[0].name 
    });
  } catch (error) {
    console.error("Error adding to cart:", error);
    res.status(500).json({ error: "Failed to add item to cart" });
  } finally {
    connection.release();
  }
};

// Update cart item quantity
export const updateCartItem: RequestHandler = async (req, res) => {
  if (!req.session?.userId) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const { cartItemId } = req.params;
  const { quantity } = req.body;

  if (!quantity || quantity < 1) {
    return res.status(400).json({ error: "Quantity must be at least 1" });
  }

  const connection = await getConnection();
  try {
    // Verify cart item belongs to user
    const [items] = await connection.query(
      `SELECT ci.id 
       FROM cart_items ci
       JOIN carts c ON ci.cart_id = c.id
       WHERE ci.id = ? AND c.user_id = ?`,
      [cartItemId, req.session.userId]
    );

    if ((items as any[]).length === 0) {
      return res.status(404).json({ error: "Cart item not found" });
    }

    await connection.query(
      "UPDATE cart_items SET quantity = ? WHERE id = ?",
      [quantity, cartItemId]
    );

    res.json({ success: true, message: "Cart updated" });
  } catch (error) {
    console.error("Error updating cart item:", error);
    res.status(500).json({ error: "Failed to update cart item" });
  } finally {
    connection.release();
  }
};

// Remove item from cart
export const removeFromCart: RequestHandler = async (req, res) => {
  if (!req.session?.userId) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const { cartItemId } = req.params;

  const connection = await getConnection();
  try {
    // Verify cart item belongs to user
    const [items] = await connection.query(
      `SELECT ci.id 
       FROM cart_items ci
       JOIN carts c ON ci.cart_id = c.id
       WHERE ci.id = ? AND c.user_id = ?`,
      [cartItemId, req.session.userId]
    );

    if ((items as any[]).length === 0) {
      return res.status(404).json({ error: "Cart item not found" });
    }

    await connection.query("DELETE FROM cart_items WHERE id = ?", [cartItemId]);

    res.json({ success: true, message: "Item removed from cart" });
  } catch (error) {
    console.error("Error removing cart item:", error);
    res.status(500).json({ error: "Failed to remove cart item" });
  } finally {
    connection.release();
  }
};

// Clear entire cart
export const clearCart: RequestHandler = async (req, res) => {
  if (!req.session?.userId) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const connection = await getConnection();
  try {
    // Get user's cart
    const [carts] = await connection.query(
      "SELECT id FROM carts WHERE user_id = ?",
      [req.session.userId]
    );

    if ((carts as any[]).length > 0) {
      const cartId = (carts as any[])[0].id;
      await connection.query("DELETE FROM cart_items WHERE cart_id = ?", [cartId]);
    }

    res.json({ success: true, message: "Cart cleared" });
  } catch (error) {
    console.error("Error clearing cart:", error);
    res.status(500).json({ error: "Failed to clear cart" });
  } finally {
    connection.release();
  }
};

// Sync cart from localStorage to database
export const syncCart: RequestHandler = async (req, res) => {
  if (!req.session?.userId) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const { items } = req.body;

  if (!Array.isArray(items)) {
    return res.status(400).json({ error: "Items must be an array" });
  }

  const connection = await getConnection();
  try {
    // Get or create cart
    let [carts] = await connection.query(
      "SELECT id FROM carts WHERE user_id = ?",
      [req.session.userId]
    );

    let cartId: string;
    if ((carts as any[]).length === 0) {
      cartId = randomUUID();
      await connection.query(
        "INSERT INTO carts (id, user_id) VALUES (?, ?)",
        [cartId, req.session.userId]
      );
    } else {
      cartId = (carts as any[])[0].id;
    }

    // Clear existing items
    await connection.query("DELETE FROM cart_items WHERE cart_id = ?", [cartId]);

    // Add all items from localStorage
    for (const item of items) {
      if (item.id && item.quantity && item.quantity > 0) {
        // Verify product exists
        const [products] = await connection.query(
          "SELECT id FROM products WHERE id = ? AND active = true",
          [item.id]
        );

        if ((products as any[]).length > 0) {
          const itemId = randomUUID();
          await connection.query(
            "INSERT INTO cart_items (id, cart_id, product_id, quantity) VALUES (?, ?, ?, ?)",
            [itemId, cartId, item.id, item.quantity]
          );
        }
      }
    }

    res.json({ success: true, message: "Cart synced" });
  } catch (error) {
    console.error("Error syncing cart:", error);
    res.status(500).json({ error: "Failed to sync cart" });
  } finally {
    connection.release();
  }
};
