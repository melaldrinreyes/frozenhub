# Development Environment Variables
# Copy this file to .env.local and update values as needed

# Node Environment
NODE_ENV=development

# Server Port
PORT=8080

# Database Configuration (Supabase Postgres)
# Set your project URL and Transaction Pooler URI from:
# Supabase Dashboard -> Project Settings -> Database -> Connection string
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<POOLER-HOST>:6543/postgres

# Optional direct connection (may fail on IPv4-only networks)
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

DATA_PROVIDER=supabase

# Session Secret (change this in production!)
SESSION_SECRET=your-secret-key-change-this-in-production

# Development Settings
# Set to true to see all API logs including auth checks
DEBUG_API=false
